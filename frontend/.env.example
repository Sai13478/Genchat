# ============================================
# Genchat Frontend Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# --- Production Backend URL ---
# VITE_API_URL=https://your-backend.com
# VITE_BACKEND_URL=https://your-backend.com

# --- Self-Hosted TURN Server ---
# Set these to use your own coturn server instead of the free fallback.
# VITE_TURN_URL can be comma-separated for multiple URLs.
# Example: turn:YOUR_PUBLIC_IP:3478,turn:YOUR_PUBLIC_IP:3478?transport=tcp
VITE_TURN_URL=turn:YOUR_PUBLIC_IP:3478
VITE_TURN_USER=genchat
VITE_TURN_CREDENTIAL=genchat123
